# Copy to .secrets/.env and fill in. NEVER commit the real file.

# --- Odoo ---
ODOO_USERNAME=unicontrolbot@yourdomain.com   # the Unicontrolbot LOGIN email
ODOO_API_KEY=                                # API key generated under the bot user's Account Security

# --- LLM (pick ONE provider) ---
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   LLM_VISION_MODEL=gpt-4o
# GLM / Zhipu:
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   LLM_MODEL=glm-4.6
#   LLM_VISION_MODEL=glm-4v
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_VISION_MODEL=

# --- Google Sheets ---
SHEETS_SPREADSHEET_ID=
